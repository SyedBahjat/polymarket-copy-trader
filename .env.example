# Your wallet private key (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# Your Polymarket proxy wallet address
PROXY_WALLET=0xYourProxyWalletAddress

# Trader addresses to copy (comma-separated)
# Find top traders at: https://polymarket.com/leaderboard
TRADER_ADDRESSES=0xTraderAddress1,0xTraderAddress2

# How much USD to spend per copy trade
COPY_AMOUNT_USD=1

# Max percentage of your balance to risk (safety limit)
MAX_BALANCE_PERCENT=50

# How often to check for new trades (in seconds)
POLL_INTERVAL=30

# Polymarket API
CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# Polygon RPC
RPC_URL=https://polygon-rpc.com

# Dashboard port
DASHBOARD_PORT=3333

# Set to "true" to simulate trades without executing
DRY_RUN=true
